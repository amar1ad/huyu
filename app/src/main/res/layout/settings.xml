<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="#0F1F1F"
	android:layoutDirection="rtl"
	android:orientation="vertical">
	<RelativeLayout
		android:id="@+id/relativelayout2"
		android:layout_width="match_parent"
		android:layout_height="60dp"
		android:background="#152A2A"
		android:paddingStart="16dp"
		android:paddingEnd="16dp">
		<ImageView
			android:id="@+id/btnBackSettings"
			android:layout_width="32dp"
			android:layout_height="32dp"
			android:padding="4dp"
			android:src="@drawable/ic_chevron_right"
			android:scaleType="center"
			android:rotation="180"
			android:tint="#4ECDC4"
			android:layout_centerVertical="true"
			android:layout_alignParentStart="true" />
		<TextView
			android:id="@+id/textview8"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="الإعدادات"
			android:textSize="20sp"
			android:textStyle="bold"
			android:textColor="#FFFFFF"
			android:layout_centerInParent="true" />
	</RelativeLayout>
	<ScrollView
		android:id="@+id/vscroll2"
		android:layout_width="match_parent"
		android:layout_height="match_parent">
		<LinearLayout
			android:id="@+id/linear3"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="20dp"
			android:orientation="vertical">
			<TextView
				android:id="@+id/textview9"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginBottom="10dp"
				android:text="إدارة البيانات"
				android:textSize="14sp"
				android:textColor="#4ECDC4" />
			<LinearLayout
				android:id="@+id/rowClearFav"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="10dp"
				android:padding="15dp"
				android:background="@drawable/bg_search_bar"
				android:gravity="center_vertical"
				android:orientation="horizontal">
				<TextView
					android:id="@+id/textview10"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:text="حذف جميع السور المفضلة"
					android:textSize="16sp"
					android:textColor="#FFFFFF"
					android:layout_weight="1" />
				<ImageView
					android:id="@+id/imageview4"
					android:layout_width="24dp"
					android:layout_height="24dp"
					android:src="@drawable/ic_star_outline"
					android:scaleType="center"
					android:tint="#D4A849" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/rowClearLastRead"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="25dp"
				android:padding="15dp"
				android:background="@drawable/bg_search_bar"
				android:gravity="center_vertical"
				android:orientation="horizontal">
				<TextView
					android:id="@+id/textview11"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:text="مسح علامة آخر قراءة"
					android:textSize="16sp"
					android:textColor="#FFFFFF"
					android:layout_weight="1" />
				<ImageView
					android:id="@+id/imageview5"
					android:layout_width="24dp"
					android:layout_height="24dp"
					android:src="@drawable/ic_quran"
					android:scaleType="center"
					android:tint="#6B8A8A" />
			</LinearLayout>
			<TextView
				android:id="@+id/textview12"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginBottom="10dp"
				android:text="حول التطبيق"
				android:textSize="14sp"
				android:textColor="#4ECDC4" />
			<LinearLayout
				android:id="@+id/linear4"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="20dp"
				android:background="@drawable/bg_search_bar"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="vertical">
				<ImageView
					android:id="@+id/imageview6"
					android:layout_width="60dp"
					android:layout_height="60dp"
					android:layout_marginBottom="10dp"
					android:src="@drawable/ic_quran"
					android:scaleType="center" />
				<TextView
					android:id="@+id/textview13"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="القرآن الكريم"
					android:textSize="18sp"
					android:textStyle="bold"
					android:textColor="#FFFFFF" />
				<TextView
					android:id="@+id/textview14"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="5dp"
					android:text="الإصدار 1.0.0"
					android:textSize="14sp"
					android:textColor="#6B8A8A" />
			</LinearLayout>
		</LinearLayout>
	</ScrollView>
</LinearLayout>
