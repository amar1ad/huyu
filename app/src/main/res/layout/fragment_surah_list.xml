<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_surah_list.xml — Fragment containing the Surah RecyclerView -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1F1F">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSurahList"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="16dp"
        android:scrollbars="none"
        tools:itemCount="10"
        tools:listitem="@layout/item_surah" />

    <!-- No Results View -->
    <LinearLayout
        android:id="@+id/layoutNoResults"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:alpha="0.4"
            android:contentDescription="لا توجد نتائج"
            android:src="@drawable/ic_search"
            android:tint="#6B8A8A" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="لا توجد نتائج"
            android:textColor="#6B8A8A"
            android:textSize="14sp" />

    </LinearLayout>

</FrameLayout>
