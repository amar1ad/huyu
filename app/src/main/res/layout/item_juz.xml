<?xml version="1.0" encoding="utf-8"?>
<!-- item_juz.xml — RecyclerView item for each Juz -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp">

    <!-- ===== Juz Number Circle ===== -->
    <FrameLayout
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/bg_juz_circle">

        <TextView
            android:id="@+id/tvJuzNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="#0F1F1F"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="1" />

    </FrameLayout>

    <!-- ===== Juz Info ===== -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvJuzName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="الجزء الأول" />

        <TextView
            android:id="@+id/tvJuzStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#6B8A8A"
            android:textSize="12sp"
            tools:text="يبدأ من: البقرة 1" />

    </LinearLayout>

    <!-- ===== Arrow Icon ===== -->
    <ImageView
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:contentDescription="فتح"
        android:rotation="180"
        android:src="@drawable/ic_chevron_right"
        android:tint="#6B8A8A" />

</LinearLayout>
