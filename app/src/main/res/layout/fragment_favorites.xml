<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_favorites.xml — Fragment containing the Favorites list -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1F1F">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFavorites"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="16dp"
        android:scrollbars="none"
        tools:itemCount="5"
        tools:listitem="@layout/item_surah" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/layoutEmptyFavorites"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:alpha="0.5"
            android:contentDescription="لا مفضلة"
            android:src="@drawable/ic_star_filled"
            android:tint="#B8932E" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="لم تقم بإضافة أي سورة للمفضلة بعد"
            android:textColor="#6B8A8A"
            android:textSize="15sp" />

    </LinearLayout>

</FrameLayout>
