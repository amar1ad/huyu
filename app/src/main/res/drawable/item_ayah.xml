<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:layout_marginBottom="8dp"
    android:background="?android:attr/selectableItemBackground"
    android:layoutDirection="rtl">

    <!-- إطار الرقم المزخرف -->
    <FrameLayout
        android:layout_width="50dp"
        android:layout_height="50dp">
        <View
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_surah_number" />
        <TextView
            android:id="@+id/tvSurahNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="1"
            android:textColor="#4ECDC4"
            android:textSize="12sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- معلومات السورة -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="15dp">

        <TextView
            android:id="@+id/tvSurahName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="اسم السورة"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">
            <TextView
                android:id="@+id/tvSurahType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مكية"
                android:textColor="#6B8A8A"
                android:textSize="12sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" • "
                android:textColor="#6B8A8A" />
            <TextView
                android:id="@+id/tvVerseCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7 آيات"
                android:textColor="#6B8A8A"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- زر المفضلة (النجمة) -->
    <ImageView
        android:id="@+id/ivFavorite"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_star_outline"
        android:tint="#6B8A8A"
        android:padding="2dp"/>

</LinearLayout>

