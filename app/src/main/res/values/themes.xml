<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ===== App Theme ===== -->
    <style name="Theme.QuranApp" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">#4ECDC4</item>
        <item name="colorPrimaryVariant">#3BA89F</item>
        <item name="colorOnPrimary">#0F1F1F</item>
        <item name="colorSecondary">#D4A849</item>
        <item name="colorSecondaryVariant">#B8932E</item>
        <item name="colorOnSecondary">#0F1F1F</item>
        <item name="android:colorBackground">#0F1F1F</item>
        <item name="colorSurface">#152A2A</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="android:statusBarColor">#0F1F1F</item>
        <item name="android:navigationBarColor">#152A2A</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- ===== Sub Tab Text Style ===== -->
    <style name="SubTabTextStyle" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="textAllCaps">false</item>
    </style>

    <!-- ===== Card Last Read Style ===== -->
    <style name="LastReadCardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">#1A4A4A</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">4dp</item>
    </style>

</resources>
